<Page x:Class="zad15_trpo.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      d:DesignHeight="575" d:DesignWidth="800"
      Title="Главная">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="2" Grid.Row="0">
            <TextBlock Text="Список электроники" HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="24"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
            <Label>Поиск</Label>
            <TextBox Text="{Binding searchQuery, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="Введите текст для поиска" 
                     TextChanged="TextBox_TextChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
            <Label FontSize="16">Сортировка</Label>
            <ComboBox SelectionChanged="ComboBox_SelectionChanged">
                <ComboBoxItem Content="Наименование" Tag="Name"/>
                <ComboBoxItem Content="Цена по возрастанию" Tag="PriceUp"/>
                <ComboBoxItem Content="Цена по убыванию" Tag="PriceDown"/>
                <ComboBoxItem Content="Количество по возрастанию" Tag="StockUp"/>
                <ComboBoxItem Content="Количество по убыванию" Tag="StockDown"/>
            </ComboBox>

            <Label FontSize="16" Margin="0,10,0,0">Фильтры</Label>

            <Label>Цена от</Label>
            <TextBox Text="{Binding filterPriceFrom, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="от" TextChanged="TextBox_TextChanged"/>
            <Label>Цена до</Label>
            <TextBox Text="{Binding filterPriceTo, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="до" TextChanged="TextBox_TextChanged"/>

            <Label FontSize="16" Margin="0,10,0,0">Бренд</Label>
            <ComboBox x:Name="BrandFilterComboBox" SelectionChanged="BrandFilter" DisplayMemberPath="Name">
            </ComboBox>

            <Label FontSize="16" Margin="0,10,0,0">Категория</Label>
            <ComboBox x:Name="CategoryFilterComboBox" SelectionChanged="CategoryFilter" DisplayMemberPath="Name">
            </ComboBox>

            <Button Content="Сбросить" Click="Button_Click" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Список товаров -->
        <materialDesign:ColorZone Grid.Row="2" Grid.Column="1" Mode="SecondaryMid">
            <ListView ItemsSource="{Binding service.Products}"
              HorizontalContentAlignment="Stretch"
              Margin="10"
              Name="ProductsList"
              ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="2" Padding="8" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Stock}" Value="0">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="1">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="2">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="3">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="4">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="5">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="6">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="7">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="8">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Stock}" Value="9">
                                            <Setter Property="BorderBrush" Value="#ffd129"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Название и цена -->
                                <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Run Text="Цена: "/>
                            <Run Text="{Binding Price, StringFormat={}{0:F2} руб.}"/>
                                </TextBlock>

                                <!-- Рейтинг -->
                                <TextBlock Grid.Row="1">
                            <Run Text="⭐ "/>
                            <Run Text="{Binding Rating}"/>
                                </TextBlock>

                                <!-- Категория и бренд -->
                                <TextBlock Grid.Row="2">
                            <Run Text="Категория: "/>
                            <Run Text="{Binding Category.Name}"/>
                            <Run Text=" | Бренд: "/>
                            <Run Text="{Binding Brand.Name}"/>
                                </TextBlock>

                                <!-- Описание и остаток -->
                                <TextBlock Grid.Row="3" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Run Text="Остаток: "/>
                            <Run Text="{Binding Stock}"/>
                                </TextBlock>

                                <!-- Теги -->
                                <ItemsControl Grid.Row="4" Grid.ColumnSpan="2" ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="#"/>
                                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </materialDesign:ColorZone>

        <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding service.Products.Count, StringFormat='{}Всего записей: {0}'}"/>
            <TextBlock Text="{Binding Items.Count, ElementName=ProductsList, StringFormat='{} Показано: {0}'}"/>
            <Button x:Name="Add" Content="Добавить товар" Click="Add_Click" Margin="10,0,5,0" Visibility="Hidden"/>
            <Button x:Name="Delete" Content="Удалить товар" Click="Delete_Click" Margin="0,0,5,0" Visibility="Hidden"/>
            <Button x:Name="Edit" Content="Категории/Бренды/Теги" Click="Edit_Click" Margin="0,0,5,0" Visibility="Hidden"/>
        </WrapPanel>
    </Grid>
</Page>