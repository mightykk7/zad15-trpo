<Page x:Class="zad15_trpo.Pages.EnterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:zad15_trpo.Pages"
      xmlns:validators="clr-namespace:zad15_trpo.Validation"
      mc:Ignorable="d" 
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Вход">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="МАГАЗИН ЭЛЕКТРОНИКИ" HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="24"/>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Content="Пароль:" Margin="5"/>
            <TextBox Grid.Column="1" VerticalAlignment="Bottom" Margin="5">
                <Binding Path="pin" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:Password/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <Button Click="Button_Click" Margin="5 15 5 5">Войти</Button>
            <Button Click="Button_Click_1" Margin="5">Войти как посетитель</Button>
        </StackPanel>

    </Grid>
</Page>
