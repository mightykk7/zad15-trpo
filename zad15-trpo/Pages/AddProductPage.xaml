<Page x:Class="zad15_trpo.Pages.AddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:zad15_trpo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Добавление товара">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.ColumnSpan="3" Grid.Row="0">
            <TextBlock Text="Добавление товара" HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="24"/>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <StackPanel Margin="0,0,0,6">
                <Label Padding="0,0,0,2">Название</Label>
                <TextBox x:Name="NameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,6">
                <Label Padding="0,0,0,2">Описание</Label>
                <TextBox x:Name="DescriptionTextBox" 
                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="44"
                 MaxHeight="72"
                 VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Padding="0,0,0,2">Цена</Label>
                    <TextBox x:Name="PriceTextBox"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Label Padding="0,0,0,2">Кол-во</Label>
                    <TextBox x:Name="StockTextBox"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <Label Padding="0,0,0,2">Рейтинг</Label>
                    <TextBox x:Name="RatingTextBox"/>
                </StackPanel>
            </Grid>
            <StackPanel Margin="0,0,0,6">
                <Label Padding="0,0,0,2">Категория</Label>
                <ComboBox x:Name="CategoryComboBox" 
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding CategoryId}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,6">
                <Label Padding="0,0,0,2">Бренд</Label>
                <ComboBox x:Name="BrandComboBox" 
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectedValue="{Binding BrandId}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,10">
                <Label FontWeight="Bold" Padding="0,0,0,2">Теги</Label>
                <ListBox x:Name="TagsListBox" 
                 DisplayMemberPath="Name"
                 SelectionMode="Multiple"
                 MinHeight="72"
                 MaxHeight="120"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,8">
                <Button Content="Отмена" Name="Back" 
                        Click="Back_Click" Width="100" Height="28" Margin="0,0,10,0"/>
                <Button Content="Сохранить" Name="Save"
                        Click="Save_Click" Width="100" Height="28"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
